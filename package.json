{
  "name": "homefs-hub",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts",
    "format": "prettier --check .",
    "docker:test:homefs-telegram-bot": "docker build -f services/homefs-telegram-bot/Dockerfile -t homefs-telegram-bot:test .",
    "docker:test:homefs-tool-server": "docker build -f services/homefs-tool-server/Dockerfile -t homefs-tool-server:test ."
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
